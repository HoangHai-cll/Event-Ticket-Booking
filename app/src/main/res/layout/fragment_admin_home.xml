<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_admin_home_welcome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chào Admin"
                    android:textColor="@color/ink_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️"
                    android:textSize="20sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Quản lý và theo dõi danh sách sự kiện của bạn."
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <!-- Custom Search Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_search_input"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="16dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/text_muted" />
                <EditText
                    android:id="@+id/et_admin_home_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:hint="Tìm kiếm sự kiện của bạn..."
                    android:textSize="14sp"
                    android:textColor="@color/ink_dark"
                    android:textColorHint="@color/text_muted"
                    android:inputType="text"
                    android:maxLines="1"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <!-- Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_filter_all"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Tất cả"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/btn_press_scale" />

                    <TextView
                        android:id="@+id/chip_filter_active"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_light"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Đang diễn ra"
                        android:textColor="@color/ink_dark"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/btn_press_scale" />

                    <TextView
                        android:id="@+id/chip_filter_drafts"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_light"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Bản nháp"
                        android:textColor="@color/ink_dark"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/btn_press_scale" />

                    <TextView
                        android:id="@+id/chip_filter_completed"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_light"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Đã kết thúc"
                        android:textColor="@color/ink_dark"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/btn_press_scale" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_admin_home_events"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_admin_event_manage" />

            <View
                android:layout_width="match_parent"
                android:layout_height="80dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_admin_home_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        app:backgroundTint="@color/brand_primary"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@color/white"
        android:contentDescription="Add Event"
        android:stateListAnimator="@animator/btn_press_scale" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
