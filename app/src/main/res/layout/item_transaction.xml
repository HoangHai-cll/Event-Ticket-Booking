<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Ảnh sự kiện -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F3F9">
                <ImageView
                    android:id="@+id/iv_transaction_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_logo_event_ticket_booking"
                    tools:ignore="ContentDescription" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Thông tin chi tiết -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_transaction_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ink_dark"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Skyline Music Festival" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tv_transaction_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        tools:text="#A1B2C3D4" />
                    <View
                        android:layout_width="3dp"
                        android:layout_height="3dp"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@color/text_muted" />
                    <TextView
                        android:id="@+id/tv_transaction_quantity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/brand_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="x2 vé" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_transaction_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    tools:text="15/12/2023 - 19:30" />
            </LinearLayout>

            <!-- Giá tiền -->
            <TextView
                android:id="@+id/tv_transaction_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginStart="8dp"
                tools:text="1.200.000đ" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F3F9"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_transaction_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="● Hoàn thành"
                tools:textColor="#10B981" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_transaction_rate"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Đánh giá"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:visibility="gone"
                tools:visibility="visible"
                app:icon="@android:drawable/btn_star_big_off"
                app:iconSize="14dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
