<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_payment"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:title="@string/label_payment_title"
            app:titleTextColor="@color/brand_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Total Amount Card (Purple gradient style) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/brand_primary">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="40dp"
                    android:paddingHorizontal="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_payment_amount"
                        android:textColor="#E0E7FF"
                        android:textSize="14sp"
                        android:alpha="0.8" />
                    <TextView
                        android:id="@+id/tv_payment_total_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        tools:text="500.000đ" />
                    <TextView
                        android:id="@+id/tv_payment_event_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#A5B4FC"
                        android:textSize="13sp"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        tools:text="Vietnam Tech Summit 2025 • 2 vé" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/label_payment_method"
                android:textStyle="bold"
                android:textColor="@color/ink_dark"
                android:textSize="17sp" />

            <!-- Payment Methods List -->
            <RadioGroup
                android:id="@+id/rg_payment_methods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <!-- Momo -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E6EE"
                    app:strokeWidth="1dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_momo_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#FDF2F8">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:contentDescription="@string/label_momo"
                                app:tint="#D1127C" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_momo_container"
                            android:layout_toStartOf="@+id/rb_momo"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_momo"
                                android:textStyle="bold"
                                android:textColor="@color/ink_dark"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_momo_desc"
                                android:textSize="12sp"
                                android:textColor="@color/text_muted" />
                        </LinearLayout>
                        <RadioButton
                            android:id="@+id/rb_momo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:checked="true"
                            app:buttonTint="@color/brand_primary" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- VNPAY -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E6EE"
                    app:strokeWidth="1dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_vnpay_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EFF6FF">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_camera"
                                android:contentDescription="@string/label_vnpay"
                                app:tint="#2563EB" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_vnpay_container"
                            android:layout_toStartOf="@+id/rb_vnpay"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_vnpay"
                                android:textStyle="bold"
                                android:textColor="@color/ink_dark"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_vnpay_desc"
                                android:textSize="12sp"
                                android:textColor="@color/text_muted" />
                        </LinearLayout>
                        <RadioButton
                            android:id="@+id/rb_vnpay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:buttonTint="@color/brand_primary" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Bank Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E6EE"
                    app:strokeWidth="1dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_bank_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F8FAFC">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_agenda"
                                android:contentDescription="@string/label_bank"
                                app:tint="@color/ink_dark" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_bank_container"
                            android:layout_toStartOf="@+id/rb_bank"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_bank"
                                android:textStyle="bold"
                                android:textColor="@color/ink_dark"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_bank_desc"
                                android:textSize="12sp"
                                android:textColor="@color/text_muted" />
                        </LinearLayout>
                        <RadioButton
                            android:id="@+id/rb_bank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:buttonTint="@color/brand_primary" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

            </RadioGroup>

            <!-- Security Notice -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F0FDF4">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:text="@string/label_security_notice"
                    android:textColor="#16A34A"
                    android:textSize="12sp"
                    app:drawableStartCompat="@android:drawable/ic_lock_idle_lock"
                    android:drawablePadding="10dp"
                    app:drawableTint="#16A34A" />
            </com.google.android.material.card.MaterialCardView>

            <View android:layout_width="match_parent" android:layout_height="100dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_pay_now"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:text="@string/btn_pay_now_format"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        app:backgroundTint="#22C55E" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
