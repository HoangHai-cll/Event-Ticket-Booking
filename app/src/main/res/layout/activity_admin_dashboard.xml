<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_radial_festive_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@color/white">

            <ImageButton
                android:id="@+id/btn_back_custom"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_back_button"
                android:contentDescription="Back"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/admin_dashboard_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/ink_dark"
                android:gravity="center"
                android:layout_marginEnd="40dp" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_admin"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Welcome Header -->
                <TextView
                    android:id="@+id/tv_admin_welcome_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_welcome_format"
                    android:textColor="@color/ink_dark"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    tools:text="Chào mừng, Admin" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tập trung vào các công cụ quản lý chính của hệ thống"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="20dp" />

                <!-- PHẦN 1: THỐNG KÊ TỔNG QUAN -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_revenue_report"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false">

                    <!-- Doanh thu Hôm nay -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/admin_revenue_today" android:textSize="11sp" />
                            <TextView android:id="@+id/tv_admin_revenue_today" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textStyle="bold" android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Doanh thu Tháng -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/admin_revenue_month" android:textSize="11sp" />
                            <TextView android:id="@+id/tv_admin_revenue_month" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textStyle="bold" android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Tổng doanh thu -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/admin_total_revenue" android:textSize="11sp" />
                            <TextView android:id="@+id/tv_admin_total_revenue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0đ" android:textStyle="bold" android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Vé đã bán -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/admin_tickets_sold" android:textSize="11sp" />
                            <TextView android:id="@+id/tv_admin_total_tickets" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Người dùng -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/admin_customers" android:textSize="11sp" />
                            <TextView android:id="@+id/tv_admin_total_users" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Rating -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        app:cardCornerRadius="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/admin_rating_avg" android:textSize="11sp" />
                            <TextView android:id="@+id/tv_admin_avg_rating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/admin_rating_default" android:textStyle="bold" android:textColor="#F59E0B" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>

                <!-- PHẦN 2: PHÂN TÍCH CHẤT LƯỢNG (SAO) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/admin_quality_analysis"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/ink_dark" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="30dp" android:layout_height="wrap_content" android:text="5 ⭐" android:textSize="11sp"/>
                            <ProgressBar android:id="@+id/pb_rating_5" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:progress="0" android:progressTint="#10B981"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                            <TextView android:layout_width="30dp" android:layout_height="wrap_content" android:text="4 ⭐" android:textSize="11sp"/>
                            <ProgressBar android:id="@+id/pb_rating_4" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:progress="0" android:progressTint="#34D399"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                            <TextView android:layout_width="30dp" android:layout_height="wrap_content" android:text="3 ⭐" android:textSize="11sp"/>
                            <ProgressBar android:id="@+id/pb_rating_3" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:progress="0" android:progressTint="#FBBF24"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                            <TextView android:layout_width="30dp" android:layout_height="wrap_content" android:text="2 ⭐" android:textSize="11sp"/>
                            <ProgressBar android:id="@+id/pb_rating_2" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:progress="0" android:progressTint="#FB923C"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="4dp">
                            <TextView android:layout_width="30dp" android:layout_height="wrap_content" android:text="1 ⭐" android:textSize="11sp"/>
                            <ProgressBar android:id="@+id/pb_rating_1" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:progress="0" android:progressTint="#EF4444"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- PHẦN 3: GIAO DỊCH MỚI NHẤT -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/admin_recent_bookings"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/ink_dark" />
                    <TextView
                        android:id="@+id/btn_admin_manage_bookings_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_all"
                        android:textColor="@color/brand_primary"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_admin_recent_bookings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false" />

                <!-- PHẦN 4: PHÂN TÍCH HIỆU QUẢ SỰ KIỆN -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/admin_analysis_top"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/ink_dark" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_admin_top_events"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- SECTION: TOP USERS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/admin_top_customers"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/ink_dark" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_admin_top_users"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- PHẦN 5: QUẢN LÝ HỆ THỐNG -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/admin_system_management"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/ink_dark" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Các chức năng quản lý cốt lõi giúp bạn điều hành sự kiện, quản lý đơn và người dùng nhanh chóng."
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp">

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:padding="16dp"
                        android:rowOrderPreserved="false"
                        android:useDefaultMargins="true">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_admin_go_to_add_event"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_add_event"
                            app:icon="@android:drawable/ic_menu_add"
                            android:textAllCaps="false"
                            android:gravity="start|center_vertical"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_admin_manage_events"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_manage_events"
                            app:icon="@android:drawable/ic_menu_edit"
                            android:textAllCaps="false"
                            android:gravity="start|center_vertical"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_admin_manage_bookings"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_manage_bookings"
                            app:icon="@android:drawable/ic_menu_agenda"
                            android:textAllCaps="false"
                            android:gravity="start|center_vertical"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_admin_manage_users"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_manage_users"
                            app:icon="@android:drawable/ic_menu_my_calendar"
                            android:textAllCaps="false"
                            android:gravity="start|center_vertical"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_admin_manage_reviews_link"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/admin_manage_reviews"
                            app:icon="@android:drawable/btn_star_big_on"
                            android:textAllCaps="false"
                            android:gravity="start|center_vertical"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_admin_manage_vouchers"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Quản lý Voucher"
                            app:icon="@android:drawable/ic_menu_send"
                            android:textAllCaps="false"
                            android:gravity="start|center_vertical"/>
                    </GridLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- PHÂN BẢNG DOANH THU THEO DANH MỤC -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/admin_category_revenue"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/ink_dark" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_admin_category_revenue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Recent Reviews -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/admin_recent_reviews"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/ink_dark" />
                    <TextView
                        android:id="@+id/btn_admin_see_all_reviews"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_all"
                        android:textColor="@color/brand_primary"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_admin_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false" />

                <View android:layout_width="match_parent" android:layout_height="40dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
