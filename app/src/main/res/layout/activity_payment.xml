<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_bg_checkout">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/white">

        <ImageButton
            android:id="@+id/btn_back_custom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_back_button"
            android:contentDescription="Back"
            android:scaleType="centerInside" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thanh toán"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/ink_dark"
            android:gravity="center"
            android:layout_marginEnd="40dp" />
    </LinearLayout>

    <!-- Stepper -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/white"
        android:gravity="center">
        
        <TextView
            android:id="@+id/tv_step1_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_circle_purple"
            android:text="1"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"/>
        <TextView
            android:id="@+id/tv_step1_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Liên hệ"
            android:textSize="12sp"
            android:textColor="@color/color_primary_periwinkle"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
            
        <View
            android:id="@+id/view_step1_divider"
            android:layout_width="32dp"
            android:layout_height="2dp"
            android:background="@color/rule_border"
            android:layout_marginHorizontal="8dp"/>
        
        <TextView
            android:id="@+id/tv_step2_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_circle_gray"
            android:text="2"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"/>
        <TextView
            android:id="@+id/tv_step2_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thanh toán"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:layout_marginStart="8dp"/>
            
        <View
            android:id="@+id/view_step2_divider"
            android:layout_width="32dp"
            android:layout_height="2dp"
            android:background="@color/rule_border"
            android:layout_marginHorizontal="8dp"/>
        
        <TextView
            android:id="@+id/tv_step3_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_circle_gray"
            android:text="3"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"/>
        <TextView
            android:id="@+id/tv_step3_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xác nhận"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
    
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/rule_border"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <ViewFlipper
            android:id="@+id/view_flipper_checkout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:measureAllChildren="false">

            <!-- STEP 1: Contact Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin người nhận vé"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_title"/>
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vé điện tử sẽ được liên kết với thông tin này."
                    android:textSize="13sp"
                    android:textColor="@color/color_text_note"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Họ và tên"
                            app:boxStrokeColor="@color/color_primary_periwinkle">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edt_checkout_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="Số điện thoại"
                            app:boxStrokeColor="@color/color_primary_periwinkle">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edt_checkout_phone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="phone"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="Email nhận vé"
                            app:boxStrokeColor="@color/color_primary_periwinkle">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edt_checkout_email"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textEmailAddress"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- STEP 2: Payment Method -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phương thức thanh toán"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_title"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn phương thức thanh toán vé của bạn"
                    android:textSize="13sp"
                    android:textColor="@color/color_text_note"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"/>

                <RadioGroup
                    android:id="@+id/rg_payment_methods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Bank Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_pm_bank"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/color_primary_periwinkle"
                        app:strokeWidth="2dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">
                            <ImageView
                                android:id="@+id/icon_bank"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@android:drawable/ic_menu_agenda"
                                app:tint="@color/ink_dark"
                                android:layout_centerVertical="true"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/icon_bank"
                                android:layout_marginStart="16dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Thẻ tín dụng / Ghi nợ"
                                    android:textStyle="bold"
                                    android:textColor="@color/ink_dark"
                                    android:textSize="15sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Visa, Mastercard"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_muted" />
                            </LinearLayout>
                            <RadioButton
                                android:id="@+id/rb_bank"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:checked="true"
                                app:buttonTint="@color/color_primary_periwinkle" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>
                    
                    <!-- Momo -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_pm_momo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/rule_border"
                        app:strokeWidth="1dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">
                            <ImageView
                                android:id="@+id/icon_momo"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@android:drawable/ic_menu_gallery"
                                app:tint="#D1127C"
                                android:layout_centerVertical="true"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/icon_momo"
                                android:layout_marginStart="16dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ví Momo"
                                    android:textStyle="bold"
                                    android:textColor="@color/ink_dark"
                                    android:textSize="15sp" />
                            </LinearLayout>
                            <RadioButton
                                android:id="@+id/rb_momo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                app:buttonTint="@color/color_primary_periwinkle" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- VNPAY -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_pm_vnpay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/rule_border"
                        app:strokeWidth="1dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">
                            <ImageView
                                android:id="@+id/icon_vnpay"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="#2563EB"
                                android:layout_centerVertical="true"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/icon_vnpay"
                                android:layout_marginStart="16dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="VNPAY"
                                    android:textStyle="bold"
                                    android:textColor="@color/ink_dark"
                                    android:textSize="15sp" />
                            </LinearLayout>
                            <RadioButton
                                android:id="@+id/rb_vnpay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                app:buttonTint="@color/color_primary_periwinkle" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>
                    
                    <!-- COD -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_pm_cod"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/rule_border"
                        app:strokeWidth="1dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">
                            <ImageView
                                android:id="@+id/icon_cod"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="#10B981"
                                android:layout_centerVertical="true"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/icon_cod"
                                android:layout_marginStart="16dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Thanh toán tại quầy sự kiện (COD)"
                                    android:textStyle="bold"
                                    android:textColor="@color/ink_dark"
                                    android:textSize="15sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nhận vé trực tiếp tại quầy"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_muted" />
                            </LinearLayout>
                            <RadioButton
                                android:id="@+id/rb_cod"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                app:buttonTint="@color/color_primary_periwinkle" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

                </RadioGroup>
            </LinearLayout>

            <!-- STEP 3: Review & Summary -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xác nhận &amp; Đặt hàng"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_title"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        
                        <!-- Event Info -->
                        <TextView
                            android:id="@+id/tv_summary_event_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tên sự kiện"
                            android:textStyle="bold"
                            android:textColor="@color/ink_dark"
                            android:textSize="16sp"/>
                        <TextView
                            android:id="@+id/tv_summary_ticket_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2 x Vé VIP"
                            android:textColor="@color/color_text_note"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"/>
                            
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/rule_border" android:layout_marginVertical="16dp"/>
                        
                        <!-- Contact Info -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Người nhận vé"
                            android:textStyle="bold"
                            android:textColor="@color/ink_dark"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tv_summary_contact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nguyen Van A - 0987654321"
                            android:textColor="@color/color_text_note"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"/>
                            
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/rule_border" android:layout_marginVertical="16dp"/>
                        
                        <!-- Payment Method -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phương thức thanh toán"
                            android:textStyle="bold"
                            android:textColor="@color/ink_dark"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tv_summary_payment_method"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thẻ tín dụng / Ghi nợ"
                            android:textColor="@color/color_text_note"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"/>
                            
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/rule_border" android:layout_marginVertical="16dp"/>
                        
                        <!-- Total -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tổng tiền thanh toán"
                                android:textStyle="bold"
                                android:textColor="@color/ink_dark"
                                android:textSize="15sp"/>
                            <TextView
                                android:id="@+id/tv_summary_total_price"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="500.000đ"
                                android:textStyle="bold"
                                android:textColor="@color/color_primary_periwinkle"
                                android:textSize="18sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ViewFlipper>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        android:padding="16dp">
        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action_next"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Tiếp tục"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/color_primary_periwinkle" />
    </LinearLayout>

</LinearLayout>
