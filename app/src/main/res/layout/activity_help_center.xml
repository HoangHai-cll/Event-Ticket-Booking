<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/white">

        <ImageButton
            android:id="@+id/btn_back_custom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_back_button"
            android:contentDescription="Back"
            android:scaleType="centerInside" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Trung tâm hỗ trợ"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/ink_dark"
            android:gravity="center"
            android:layout_marginEnd="40dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chúng tôi có thể giúp gì cho bạn?"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/ink_dark" />

            <!-- Search box -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/text_muted"
                        tools:ignore="ContentDescription" />
                    <EditText
                        android:id="@+id/edt_search_faq"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@null"
                        android:hint="Tìm kiếm câu hỏi, chủ đề, từ khóa..."
                        android:textSize="14sp"
                        android:inputType="text"
                        android:importantForAutofill="no" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/rule_border" android:layout_marginVertical="24dp"/>

            <!-- Support Categories Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- Booking -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🗓️ Đặt vé" android:textStyle="bold" android:textColor="@color/ink_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sửa đổi, hủy hoặc theo dõi vé" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Payment -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💵 Thanh toán" android:textStyle="bold" android:textColor="@color/ink_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hoàn tiền, hóa đơn, phương thức" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Account -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤 Tài khoản" android:textStyle="bold" android:textColor="@color/ink_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đăng nhập, bảo mật, cài đặt" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- General -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="❓ Chung" android:textStyle="bold" android:textColor="@color/ink_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thông tin ứng dụng, chính sách" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Câu hỏi thường gặp"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/ink_dark" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tất cả"
                    android:textColor="@color/brand_primary"
                    android:textStyle="bold"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- FAQ List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <!-- FAQ Item 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_faq_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <LinearLayout
                            android:id="@+id/layout_faq_header_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:id="@+id/tv_faq_question_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Làm thế nào để được hoàn tiền vé?" android:textStyle="bold" android:textColor="@color/ink_dark"/>
                            <ImageView android:id="@+id/iv_faq_arrow_1" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/arrow_down_float" app:tint="@color/text_muted"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tv_faq_answer_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            android:lineSpacingExtra="4dp"
                            android:visibility="gone"
                            android:text="Để được hoàn tiền vé, vui lòng gửi yêu cầu hoàn tiền thông qua mục Chi tiết vé ít nhất 24 giờ trước khi sự kiện diễn ra. Tiền sẽ được hoàn về tài khoản thanh toán ban đầu của bạn trong vòng 3-5 ngày làm việc."/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- FAQ Item 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_faq_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <LinearLayout
                            android:id="@+id/layout_faq_header_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:id="@+id/tv_faq_question_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tôi có thể chuyển nhượng vé cho bạn bè không?" android:textStyle="bold" android:textColor="@color/ink_dark"/>
                            <ImageView android:id="@+id/iv_faq_arrow_2" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/arrow_down_float" app:tint="@color/text_muted"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tv_faq_answer_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            android:lineSpacingExtra="4dp"
                            android:visibility="gone"
                            android:text="Có, bạn có thể dễ dàng chuyển nhượng vé bằng cách nhập email tài khoản của bạn bè trong phần quản lý vé và nhấn 'Chuyển vé'."/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- FAQ Item 3 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_faq_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <LinearLayout
                            android:id="@+id/layout_faq_header_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:id="@+id/tv_faq_question_3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Điều gì xảy ra nếu sự kiện bị hủy?" android:textStyle="bold" android:textColor="@color/ink_dark"/>
                            <ImageView android:id="@+id/iv_faq_arrow_3" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/arrow_down_float" app:tint="@color/text_muted"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tv_faq_answer_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            android:lineSpacingExtra="4dp"
                            android:visibility="gone"
                            android:text="Trong trường hợp sự kiện bị hủy, ban tổ chức sẽ tự động hoàn 100% tiền vé cho bạn. Bạn sẽ nhận được thông báo qua email và ứng dụng về lịch trình hoàn tiền cụ thể."/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Bạn vẫn cần trợ giúp?"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/ink_dark" />

            <!-- Support Live Chat Mockup -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/brand_light_purple">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/stat_notify_chat" app:tint="@color/brand_primary"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trò chuyện trực tiếp" android:textStyle="bold" android:textColor="@color/brand_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thời gian chờ dự kiến: 2 phút" android:textSize="11sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_next" app:tint="@color/brand_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View android:layout_width="match_parent" android:layout_height="40dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>