<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/rule_border"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Ảnh sơ đồ chỗ ngồi (nếu có) -->
        <ImageView
            android:id="@+id/iv_tier_seatmap"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical">

            <!-- Radio button chọn -->
            <RadioButton
                android:id="@+id/rb_tier_select"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/brand_primary"
                android:clickable="false"
                android:focusable="false" />

            <!-- Tên + Còn lại -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tv_tier_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ink_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:text="VIP" />

                <TextView
                    android:id="@+id/tv_tier_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:text="Còn 50 vé" />
            </LinearLayout>

            <!-- Giá -->
            <TextView
                android:id="@+id/tv_tier_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="500,000đ" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
