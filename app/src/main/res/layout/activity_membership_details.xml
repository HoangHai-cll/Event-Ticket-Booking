<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_radial_festive_light">

    <!-- Top Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@android:color/transparent">
        <ImageButton
            android:id="@+id/btn_back_membership"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/ink_dark"
            android:contentDescription="Quay lại"
            android:stateListAnimator="@animator/btn_press_scale" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Thứ hạng &amp; Đặc quyền"
            android:textColor="@color/ink_dark"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Current Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/rule_border"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thứ hạng hiện tại"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/tv_current_tier_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Hạng Bạc"
                            android:textColor="@color/ink_dark"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tv_current_exp_ratio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1500 / 3500 EXP"
                            android:textColor="@color/brand_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Progress Bar to Next Level -->
                    <ProgressBar
                        android:id="@+id/pb_upgrade_progress"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="16dp"
                        android:progress="42"
                        android:max="100"
                        android:progressTint="@color/brand_primary"
                        android:progressBackgroundTint="@color/rule_border" />

                    <!-- Upgrade Goal details -->
                    <TextView
                        android:id="@+id/tv_upgrade_target_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Cần thêm 2000 EXP nữa để thăng hạng Vàng"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Benefits timeline Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thang đặc quyền thành viên 📈"
                android:textColor="@color/ink_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Ascending Privileges Stack: Bottom to Top (Thường -> VIP) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 5. Hạng Tối Cao: THÂN THIẾT SỐ MỘT (VIP) (TOP OF THE LIST) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_tier_vip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/star_gold"
                    app:cardBackgroundColor="#FFFDF0"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="👑 Thân thiết số một (7500+ EXP)"
                                android:textColor="@color/brand_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cấp độ 5 (Tối cao)"
                                android:textColor="@color/star_gold"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="• Tặng gói Voucher cực VIP: Giảm giá 20% và 50% đơn hàng.\n• Quyền mua vé ưu tiên cao nhất cho tất cả các sự kiện độc quyền/giới hạn.\n• Hoàn toàn miễn phí dịch vụ đặt vé (0đ phí dịch vụ).\n• Kênh hỗ trợ khách hàng VIP 24/7 trực tiếp.\n• Nhân 2.0x lượng EXP tích lũy khi mua vé."
                            android:textColor="@color/ink_dark"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. Hạng Cao Cấp: VÀNG -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_tier_gold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/brand_primary"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="⭐️ Hạng Vàng (3500 - 7499 EXP)"
                                android:textColor="@color/ink_dark"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cấp độ 4"
                                android:textColor="@color/brand_primary"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="• Tặng gói Voucher Vàng: Giảm giá 15% và 20% đơn hàng.\n• Quyền mua vé ưu tiên cho các sự kiện giới hạn hạng Vàng.\n• Hỗ trợ nhanh chóng qua cổng ưu tiên chăm sóc khách hàng.\n• Nhân 1.5x lượng EXP tích lũy khi mua vé."
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. Hạng Trung Cấp: BẠC -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_tier_silver"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/text_muted"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="💿 Hạng Bạc (1500 - 3499 EXP)"
                                android:textColor="@color/ink_dark"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cấp độ 3"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="• Tặng gói Voucher Bạc: Giảm giá 10% và 15% đơn hàng.\n• Đăng ký mua vé trước các sự kiện đại chúng dành cho hạng Bạc.\n• Nhân 1.2x lượng EXP tích lũy khi mua vé."
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. Hạng Sơ Cấp: ĐỒNG -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_tier_bronze"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#CD7F32"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🥉 Hạng Đồng (500 - 1499 EXP)"
                                android:textColor="@color/ink_dark"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cấp độ 2"
                                android:textColor="#CD7F32"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="• Tặng gói Voucher Đồng: Giảm giá 5% và 10% đơn hàng.\n• Nhân 1.1x lượng EXP tích lũy khi mua vé."
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 1. Hạng Cơ Bản: THƯỜNG (BOTTOM OF THE LIST) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_tier_regular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/rule_border"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🌱 Hạng Thường (0 - 499 EXP)"
                                android:textColor="@color/ink_dark"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cấp độ 1"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="• Tích lũy điểm EXP cơ bản khi đặt mua vé.\n• Nhận Voucher chào mừng người dùng mới (HOAN100XU)."
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
