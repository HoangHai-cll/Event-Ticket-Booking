<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Event_Ticket_Booking_App" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:windowBackground">@drawable/bg_radial_festive_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary_dark</item>
        <item name="colorAccent">@color/brand_primary</item>

        <!-- Global Shape Appearances according to DESIGN.md -->
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.EventPass.Medium</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.EventPass.Small</item>
    </style>

    <style name="Theme.Event_Ticket_Booking_App" parent="Base.Theme.Event_Ticket_Booking_App" />

    <style name="ShapeAppearance.EventPass.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">@dimen/card_corner_radius</item>
    </style>

    <style name="ShapeAppearance.EventPass.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">@dimen/button_corner_radius</item>
    </style>

    <!-- Sao vàng cho RatingBar -->
    <style name="GoldRatingBar" parent="Widget.AppCompat.RatingBar.Small">
        <item name="colorControlNormal">@color/star_gold</item>
        <item name="colorControlActivated">@color/star_gold</item>
        <item name="colorAccent">@color/star_gold</item>
    </style>

    <style name="GoldRatingBarLarge" parent="Widget.AppCompat.RatingBar">
        <item name="colorControlNormal">@color/star_gold</item>
        <item name="colorControlActivated">@color/star_gold</item>
        <item name="colorAccent">@color/star_gold</item>
    </style>
</resources>