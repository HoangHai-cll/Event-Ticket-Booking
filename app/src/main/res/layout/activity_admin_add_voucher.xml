<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@color/white">

            <ImageButton
                android:id="@+id/btn_back_custom"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_back_button"
                android:contentDescription="Back"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Thêm Voucher"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/ink_dark"
                android:gravity="center"
                android:layout_marginEnd="40dp" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mã Voucher (viết liền, vd: CODETOT10)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edt_voucher_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapCharacters" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Tiêu đề hiển thị (vd: Hoàn 100% xu)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edt_voucher_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại chiết khấu"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:textColor="@color/ink_dark" />

            <RadioGroup
                android:id="@+id/rg_discount_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">
                <RadioButton
                    android:id="@+id/rb_type_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Theo phần trăm (%)"
                    android:checked="true" />
                <RadioButton
                    android:id="@+id/rb_type_fixed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="Số tiền mặt (VNĐ)" />
            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Giá trị giảm giá (vd: 100 cho 100%, 50000 cho 50k)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edt_voucher_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Đơn hàng tối thiểu (VNĐ)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edt_voucher_min_order"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="0" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Giảm tối đa (VNĐ) — dùng nếu chọn phần trăm">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edt_voucher_max_discount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="0" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thời gian hết hạn *"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:textColor="@color/ink_dark" />

            <TextView
                android:id="@+id/tv_voucher_expiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Chưa chọn ngày hết hạn"
                android:textColor="@color/brand_primary"
                android:gravity="center"
                android:padding="12dp"
                android:background="@drawable/bg_chip_light"
                android:textStyle="bold"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_expiry"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Chọn ngày và giờ hết hạn"
                app:strokeColor="@color/brand_primary"
                app:cornerRadius="12dp"/>

            <CheckBox
                android:id="@+id/cb_system_default"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Đặt làm Voucher hệ thống mặc định tặng người mới"
                android:buttonTint="@color/brand_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_voucher"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Lưu Voucher"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/brand_primary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
