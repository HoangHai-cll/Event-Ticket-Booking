<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/brand_primary"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageButton
                    android:id="@+id/btn_back_custom"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_back_button"
                    android:contentDescription="Back"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Đăng sự kiện"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:layout_marginEnd="40dp" />
            </LinearLayout>

            <!-- Step Indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:gravity="center">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_step_1_num" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_chip" android:text="1" android:gravity="center" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_step_1_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thông tin" android:textSize="10sp" android:layout_marginTop="4dp" android:textColor="@color/white"/>
                </LinearLayout>

                <View android:id="@+id/view_step1_divider" android:layout_width="30dp" android:layout_height="1dp" android:background="#66FFFFFF" android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_step_2_num" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_chip_light" android:text="2" android:gravity="center" android:textColor="@color/text_muted" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_step_2_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vé &amp; Giá" android:textSize="10sp" android:layout_marginTop="4dp" android:textColor="#AAFFFFFF"/>
                </LinearLayout>

                <View android:id="@+id/view_step2_divider" android:layout_width="30dp" android:layout_height="1dp" android:background="#66FFFFFF" android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tv_step_3_num" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/bg_chip_light" android:text="3" android:gravity="center" android:textColor="@color/text_muted" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_step_3_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Xuất bản" android:textSize="10sp" android:layout_marginTop="4dp" android:textColor="#AAFFFFFF"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- STEP 1: THÔNG TIN CƠ BẢN -->
            <LinearLayout
                android:id="@+id/layout_step_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="visible">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ảnh bìa sự kiện" android:textStyle="bold" android:textSize="13sp" android:layout_marginBottom="8dp"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/brand_primary"
                    app:strokeWidth="1dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <ImageView android:id="@+id/iv_admin_preview_image" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:gravity="center" android:orientation="vertical">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_camera" app:tint="@color/brand_primary"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dán URL ảnh xuống dưới" android:textColor="@color/brand_primary" android:textSize="12sp" android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="URL Ảnh bìa">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/edt_admin_image" android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Tên sự kiện *">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/edt_admin_title" android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Danh mục *" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Chọn danh mục">
                    <AutoCompleteTextView android:id="@+id/spinner_admin_category" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Địa điểm tổ chức *">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/edt_admin_location" android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Link Google Maps (tùy chọn)">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/edt_admin_google_maps" android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Mô tả sự kiện *">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/edt_admin_desc" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="top" android:lines="5" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Diễn giả / Ban tổ chức">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/edt_admin_speakers" android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- STEP 2: VÉ & GIÁ -->
            <LinearLayout
                android:id="@+id/layout_step_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" app:cardCornerRadius="16dp" app:strokeColor="@color/rule_border" app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sự kiện miễn phí" android:textStyle="bold" android:textSize="15sp"/>
                            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_admin_is_free" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_admin_price"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Giá vé (VNĐ) *">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/edt_admin_price" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="Tổng số lượng vé *">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/edt_admin_total_tickets" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thời gian tổ chức *" android:textStyle="bold" android:layout_marginTop="20dp"/>
                        <TextView android:id="@+id/tv_admin_datetime" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Chưa chọn thời gian" android:textColor="@color/brand_primary" android:gravity="center" android:padding="12dp" android:background="@drawable/bg_chip_light" android:textStyle="bold"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btn_admin_pick_date" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Chọn ngày và giờ" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:strokeColor="@color/brand_primary" app:cornerRadius="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <CheckBox android:id="@+id/cb_admin_is_hot" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Đánh dấu là Sự kiện Hot 🔥" android:buttonTint="@color/brand_primary" />
            </LinearLayout>

            <!-- STEP 3: XUẤT BẢN -->
            <LinearLayout
                android:id="@+id/layout_step_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center"
                android:visibility="gone">

                <ImageView android:layout_width="100dp" android:layout_height="100dp" android:src="@android:drawable/checkbox_on_background" app:tint="#10B981"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sẵn sàng xuất bản!" android:textStyle="bold" android:textSize="20sp" android:layout_marginTop="16dp" android:textColor="@color/ink_dark"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vui lòng kiểm tra kỹ các thông tin trước khi đưa sự kiện lên hệ thống công khai." android:gravity="center" android:layout_marginTop="8dp" android:textColor="@color/text_muted"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:orientation="vertical">
                        <TextView android:id="@+id/tv_preview_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên sự kiện" android:textStyle="bold" android:textColor="@color/ink_dark"/>
                        <TextView android:id="@+id/tv_preview_info" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thông tin tóm tắt" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:padding="16dp" android:background="@color/white" android:elevation="8dp" android:orientation="horizontal">
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_admin_prev" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="Quay lại" style="@style/Widget.MaterialComponents.Button.TextButton" android:visibility="invisible"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_admin_next" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="2" android:layout_marginStart="12dp" android:text="Tiếp tục" app:cornerRadius="14dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_admin_save" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="2" android:layout_marginStart="12dp" android:text="Đăng sự kiện ngay" app:cornerRadius="14dp" android:visibility="gone" app:backgroundTint="#10B981"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>