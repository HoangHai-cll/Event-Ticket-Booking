<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageButton
                android:id="@+id/btn_menu_drawer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu"
                app:tint="@color/brand_primary"
                android:layout_marginEnd="8dp" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/brand_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
            <ImageView
                android:id="@+id/iv_profile_top"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_profile_nav"
                app:tint="@color/brand_primary"
                android:background="@drawable/bg_circle_gray"
                android:contentDescription="Profile" />
        </LinearLayout>

        <!-- Search (Ẩn cho Admin) -->
        <LinearLayout
            android:id="@+id/layout_search"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_search_input">
            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="10dp"
                android:hint="@string/search_hint"
                android:padding="14dp"
                android:textColor="@color/ink_dark"
                android:textSize="14sp"
                android:inputType="text" />
        </LinearLayout>

        <!-- FRAME: HOT EVENTS (Ẩn cho Admin) -->
        <LinearLayout
            android:id="@+id/layout_hot_events"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_hot_events_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/hot_events_title"
                android:textColor="@color/ink_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_hot_events"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
        </LinearLayout>

        <!-- FRAME: ALL EVENTS -->
        <LinearLayout
            android:id="@+id/layout_all_events_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tv_all_events_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/register_events_title"
                android:textColor="@color/ink_dark"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_see_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/see_all"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/btn_press_scale" />
        </LinearLayout>

        <!-- Time Filters: Sắp tới vs Đã diễn ra (Ẩn cho Admin) -->
        <LinearLayout
            android:id="@+id/layout_time_filters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/chip_upcoming"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Sắp tới"
                android:textColor="@color/white"
                android:background="@drawable/bg_chip"
                android:textStyle="bold"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/btn_press_scale" />

            <TextView
                android:id="@+id/chip_past"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:text="Đã diễn ra"
                android:textColor="@color/ink_dark"
                android:background="@drawable/bg_chip_light"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/btn_press_scale" />
        </LinearLayout>

        <!-- Categories (Ẩn cho Admin) -->
        <HorizontalScrollView
            android:id="@+id/layout_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/chip_music"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/cat_music"
                    android:textColor="@color/ink_dark"
                    android:background="@drawable/bg_chip_light"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/btn_press_scale" />
                <TextView
                    android:id="@+id/chip_seminar"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/cat_seminar"
                    android:textColor="@color/ink_dark"
                    android:background="@drawable/bg_chip_light"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/btn_press_scale" />
                <TextView
                    android:id="@+id/chip_workshop"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/cat_workshop"
                    android:textColor="@color/ink_dark"
                    android:background="@drawable/bg_chip_light"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/btn_press_scale" />
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_events"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginTop="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>