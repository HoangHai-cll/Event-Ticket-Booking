<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_dialog">

    <TextView
        android:id="@+id/tv_qr_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mã vé của bạn"
        android:textColor="@color/ink_dark"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <ImageView
        android:id="@+id/iv_qr_code"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/tv_qr_locked_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mã QR và tính năng tải vé sẽ tự động kích hoạt 24 giờ trước khi sự kiện bắt đầu."
        android:textColor="#EAB308"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_qr_booking_id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ID: #12345678"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_cancel_ticket"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hủy vé &amp; Hoàn tiền"
        android:textColor="@color/white"
        android:backgroundTint="#EF4444"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_qr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lưu vé vào thư viện 💾"
        android:textColor="@color/brand_primary"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_qr_close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đóng"
        android:backgroundTint="@color/brand_primary" />
</LinearLayout>
