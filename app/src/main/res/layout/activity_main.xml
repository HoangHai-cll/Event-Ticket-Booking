<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_radial_festive_light">

    <!-- Main Content (Old activity_main layout) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:background="@color/white"
            android:padding="12dp"
            android:baselineAligned="false"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:id="@+id/nav_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/btn_press_scale">
                <ImageView
                    android:id="@+id/iv_nav_home_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_home"
                    app:tint="@color/brand_primary" />
                <TextView
                    android:id="@+id/tv_nav_home_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_home"
                    android:textSize="11sp"
                    android:textColor="@color/brand_primary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_scan_qr"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                android:stateListAnimator="@animator/btn_press_scale">
                <ImageView
                    android:id="@+id/iv_nav_scan_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_qr_scan"
                    app:tint="@color/text_muted" />
                <TextView
                    android:id="@+id/tv_nav_scan_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quét mã"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_admin"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                android:stateListAnimator="@animator/btn_press_scale">
                <ImageView
                    android:id="@+id/iv_nav_admin_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_admin"
                    app:tint="@color/text_muted" />
                <TextView
                    android:id="@+id/tv_nav_admin_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quản lý"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_tickets"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/btn_press_scale">
                <ImageView
                    android:id="@+id/iv_nav_tickets_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_tickets"
                    app:tint="@color/text_muted" />
                <TextView
                    android:id="@+id/tv_nav_tickets_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_tickets"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_history"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/btn_press_scale">
                <ImageView
                    android:id="@+id/iv_nav_history_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_history"
                    app:tint="@color/text_muted" />
                <TextView
                    android:id="@+id/tv_nav_history_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_history"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_profile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/btn_press_scale">
                <ImageView
                    android:id="@+id/iv_nav_profile_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_profile_nav"
                    app:tint="@color/text_muted" />
                <TextView
                    android:id="@+id/tv_nav_profile_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_profile"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_drawer"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/bg_radial_festive_light"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/drawer_menu"
        app:itemIconTint="@color/brand_primary"
        app:itemTextColor="@color/ink_dark" />

</androidx.drawerlayout.widget.DrawerLayout>