<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_user_avatar_char"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_gray"
            android:gravity="center"
            android:textColor="@color/brand_primary"
            android:textStyle="bold"
            android:textSize="18sp"
            tools:text="H" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_user_item_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ink_dark"
                android:textStyle="bold"
                android:textSize="15sp"
                tools:text="Nguyễn Văn Hải" />

            <TextView
                android:id="@+id/tv_user_item_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                tools:text="hai@gmail.com" />

            <!-- Phase C: Hiển thị Hạng và EXP -->
            <TextView
                android:id="@+id/tv_user_item_tier_exp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                tools:text="🏅 Đồng • EXP: 750" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_user_item_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_chip_light"
            android:textColor="@color/brand_primary"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="ADMIN" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>