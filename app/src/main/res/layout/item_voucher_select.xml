<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/rule_border"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal">

        <!-- Left Ticket Section (Shopee brand color) -->
        <LinearLayout
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:background="@color/brand_primary"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="EventPass"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dashed Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#D0D4DC" />

        <!-- Right Voucher Info Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_voucher_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ink_dark"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Hoàn 100% xu" />

            <!-- Subtitle/Conditions -->
            <TextView
                android:id="@+id/tv_voucher_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_voucher_title"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                tools:text="Đơn tối thiểu từ 0đ • Giảm tối đa 88k" />

            <!-- Expiry -->
            <TextView
                android:id="@+id/tv_voucher_expiry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:textColor="@color/error"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="HSD: 09:00 ngày 12/01/2021" />

            <!-- Selection Widget (Checkbox/RadioButton/Delete button) -->
            <RadioButton
                android:id="@+id/rb_voucher_select"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:clickable="false"
                android:focusable="false"
                android:buttonTint="@color/brand_primary"
                android:visibility="gone" />

            <!-- Delete button for Admin Management view -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_voucher"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:text="Xóa"
                android:textColor="@color/error"
                android:textSize="11sp"
                android:visibility="gone" />
        </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
